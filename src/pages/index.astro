---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Origin from '../components/Origin.astro';
import Why from '../components/Why.astro';
import Product from '../components/Product.astro';
import Vision from '../components/Vision.astro';
import Team from '../components/Team.astro';
import Contact from '../components/Contact.astro';
import Waitlist from '../components/Waitlist.astro';
import Footer from '../components/Footer.astro';
---

<div id="aa-panel">
  <div class="aa-title">Text Size</div>
  <div class="aa-controls">
    <button id="aa-dec" class="aa-step" aria-label="Decrease text size">-</button>
    <span id="aa-label" class="aa-label">Medium</span>
    <button id="aa-inc" class="aa-step" aria-label="Increase text size">+</button>
  </div>
  <div class="aa-title" style="margin-top:20px;">Preview</div>
  <div id="aa-preview">The quick brown fox</div>
</div>

<script>
  const sizes = [
    { label: 'Small',   scale: 0.85 },
    { label: 'Medium',  scale: 1.00 },
    { label: 'Large',   scale: 1.15 },
    { label: 'X-Large', scale: 1.30 },
  ];
  let current = 1;

  const panel = document.getElementById('aa-panel');
  const btn = document.querySelector<HTMLButtonElement>('.aa-btn');
  const dec = document.getElementById('aa-dec');
  const inc = document.getElementById('aa-inc');
  const label = document.getElementById('aa-label');
  const preview = document.getElementById('aa-preview');

  function applySize() {
    const s = sizes[current];
    document.documentElement.style.fontSize = (16 * s.scale) + 'px';
    if (label) label.textContent = s.label;
    if (preview) preview.style.fontSize = (15 * s.scale) + 'px';
  }

  function setPanelOpen(open: boolean) {
    if (!panel || !btn) return;
    panel.style.display = open ? 'block' : 'none';
    btn.setAttribute('aria-expanded', String(open));
  }

  if (panel && btn && dec && inc) {
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      setPanelOpen(panel.style.display !== 'block');
    });

    dec.addEventListener('click', () => {
      current = Math.max(0, current - 1);
      applySize();
    });

    inc.addEventListener('click', () => {
      current = Math.min(sizes.length - 1, current + 1);
      applySize();
    });

    document.addEventListener('click', (e) => {
      if (!panel.contains(e.target as Node) && e.target !== btn) {
        setPanelOpen(false);
      }
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && panel.style.display === 'block') {
        setPanelOpen(false);
        btn.focus();
      }
    });
  }
</script>

<BaseLayout>
  <Nav />
  <main id="main">
    <Hero />
    <div class="divider"></div>
    <Origin />
    <div class="divider"></div>
    <Why />
    <Product />
    <div class="divider"></div>
    <Vision />
    <div class="divider"></div>
    <Team />
    <div class="divider"></div>
    <Contact />
    <Waitlist />
  </main>
  <Footer />
</BaseLayout>

<script>
  import '../scripts/canvas.ts';
</script>