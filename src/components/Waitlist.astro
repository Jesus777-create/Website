---
// Formspree form ID. Set PUBLIC_FORMSPREE_ID in `.env` (see .env.example).
// Until it's set, the form falls back gracefully and logs a clear warning.
const formId = import.meta.env.PUBLIC_FORMSPREE_ID ?? '';
const action = formId ? `https://formspree.io/f/${formId}` : '';
---

<div class="footer-cta" id="waitlist">
  <h2>Be the first to feel it.</h2>
  <p>
    Beta opens to deaf, hard of hearing, blind, visually impaired, and deafblind community
    members first. Join the waitlist.
  </p>

  <form class="wl-form" id="wl-form" action={action} method="POST" data-has-action={String(!!action)}>
    <label class="sr-only" for="wl-email">Email address</label>
    <input
      class="wl-input"
      type="email"
      id="wl-email"
      name="email"
      autocomplete="email"
      required
      placeholder="your@email.com"
    />
    <button class="btn-p" type="submit">Join waitlist</button>
  </form>

  <p id="wl-ok" role="status">You're on the list. We'll be in touch.</p>

  <div style="margin-top:28px;display:flex;gap:12px;justify-content:center;flex-wrap:wrap;">
    <a href="mailto:hello@accesswave.tech" class="btn-s" style="font-size:13px;padding:10px 20px;">
      Contact us
    </a>
    <a href="#" class="btn-s" style="font-size:13px;padding:10px 20px;">Investor deck</a>
  </div>
</div>

<script>
  const form = document.getElementById('wl-form') as HTMLFormElement | null;
  const ok = document.getElementById('wl-ok');

  if (form && ok) {
    const hasAction = form.dataset.hasAction === 'true';

    form.addEventListener('submit', async (e) => {
      // No backend configured yet: confirm visually but warn the developer.
      if (!hasAction) {
        e.preventDefault();
        console.warn(
          '[AccessWave] Waitlist not yet connected. Set PUBLIC_FORMSPREE_ID in .env to receive signups.'
        );
        ok.style.display = 'block';
        form.reset();
        return;
      }

      // Progressive enhancement: submit via fetch so the user stays on the page.
      // If JS is disabled, the native POST to Formspree still works.
      e.preventDefault();
      const button = form.querySelector('button');
      const data = new FormData(form);

      try {
        if (button) button.disabled = true;
        const res = await fetch(form.action, {
          method: 'POST',
          body: data,
          headers: { Accept: 'application/json' },
        });

        if (res.ok) {
          ok.textContent = "You're on the list. We'll be in touch.";
          ok.style.display = 'block';
          form.reset();
        } else {
          ok.textContent = 'Something went wrong — please try again or email us.';
          ok.style.display = 'block';
        }
      } catch {
        ok.textContent = 'Network error — please try again or email us.';
        ok.style.display = 'block';
      } finally {
        if (button) button.disabled = false;
      }
    });
  }
</script>
