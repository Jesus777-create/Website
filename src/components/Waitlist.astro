---
---

<div class="footer-cta" id="waitlist">
  <h2>Be the first to feel it.</h2>
  <p>
    Beta opens to deaf, hard of hearing, blind, visually impaired, and deafblind community
    members first. Join the waitlist.
  </p>

  <form class="wl-form" id="wl-form">
    <label class="sr-only" for="wl-email">Email address</label>
    <input
      class="wl-input"
      type="email"
      id="wl-email"
      name="email"
      autocomplete="email"
      required
      placeholder="your@email.com"
    />
    <button class="btn-p" type="submit">Join waitlist</button>
  </form>

  <p id="wl-ok" role="status">You're on the list. We'll be in touch.</p>

  <div style="margin-top:28px;display:flex;gap:12px;justify-content:center;flex-wrap:wrap;">
    <a href="mailto:hello@accesswave.tech" class="btn-s" style="font-size:13px;padding:10px 20px;">
      Contact us
    </a>
    <a href="#" class="btn-s" style="font-size:13px;padding:10px 20px;">Investor deck</a>
  </div>
</div>

<script>
  const SCRIPT_URL = 'https://script.google.com/macros/s/AKfycbyVUdGMlMVQRJMz0Nr6RTAFTe3qfw823ABHBLqIRpzkKZIYghxadxT0xoKHRrUSiXUJGg/exec';

  const form = document.getElementById('wl-form') as HTMLFormElement | null;
  const ok = document.getElementById('wl-ok');

  if (form && ok) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const button = form.querySelector('button') as HTMLButtonElement | null;
      const email = (document.getElementById('wl-email') as HTMLInputElement).value;

      try {
        if (button) button.disabled = true;

        const res = await fetch(SCRIPT_URL, {
          method: 'POST',
          body: new URLSearchParams({ email }),
        });

        const text = await res.text();

        if (text === 'Already registered') {
          ok.textContent = "You're already on the list!";
        } else {
          ok.textContent = "You're on the list. We'll be in touch.";
        }

        ok.style.display = 'block';
        form.reset();

      } catch {
        ok.textContent = 'Network error — please try again or email us.';
        ok.style.display = 'block';
      } finally {
        if (button) button.disabled = false;
      }
    });
  }
</script>