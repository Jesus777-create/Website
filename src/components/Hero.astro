---
const stats = [
  { n: '70M+', l: 'Americans affected' },
  { n: '$26B', l: 'U.S. addressable market' },
  { n: '<5%', l: 'Digital products accessible' },
];
---

<section class="hero" style="max-width:100%;padding-left:0;padding-right:0;">
  <canvas id="hero-c" aria-hidden="true"></canvas>
  <div class="hero-inner">
    <div class="eyebrow">AccessWave Technologies &nbsp;·&nbsp; Pre-seed</div>
    <h1>Sound you've never heard —<br /><em>felt for the first time.</em></h1>
    <p class="hero-sub">
      We build software and hardware that translates the emotional world of sound
      into touch — purpose-built <em>with</em> deaf, hard of hearing, blind, visually
      impaired, and deafblind communities.
    </p>
    <div class="hero-btns">
      <a href="#product" class="btn-p">See the product</a>
      <a href="#mission" class="btn-s">Our story</a>
    </div>
    <div class="hero-stats">
      {
        stats.map((s) => (
          <div>
            <div class="stat-n">{s.n}</div>
            <div class="stat-l">{s.l}</div>
          </div>
        ))
      }
    </div>
  </div>
</section>
